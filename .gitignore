# ============================================================================
# BCK Manager WEB - .gitignore
# ============================================================================

BCK_Manager/*
BCK_Manager

# --- Credentials & secrets ---
# Never commit the actual config with real credentials
config.yaml

# --- Local documentation (not for git) ---
tool_backup.md

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
wheels/
.eggs/

# --- Virtual environments ---
venv/
.venv/
env/
.env/
ENV/

# --- Environment files ---
.env
.env.*
!.env.example

# --- Logs ---
*.log
bck_manager.log

# --- Temp / OS artifacts ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# --- Archives created during testing ---
*.tar.gz
*.tar.bz2
*.tar.xz
*.enc

# --- pytest / coverage ---
.pytest_cache/
.coverage
htmlcov/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
