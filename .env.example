# ============================================================================
# BCK Manager Web — Environment Variables
# ============================================================================
# Copy to .env and fill in real values.

# Deployment mode: "standalone" (single server) | "hub" (fleet management)
BCK_WEB_MODE=standalone

# Uvicorn bind (Caddy proxies to this — do NOT expose to network)
BCK_WEB_HOST=127.0.0.1
BCK_WEB_PORT=8080

# Secret key for JWT signing — CHANGE THIS to a strong random string (min 32 chars)
# Generate one:  python3 -c "import secrets; print(secrets.token_urlsafe(48))"
BCK_WEB_SECRET_KEY=CHANGE_ME_STRONG_RANDOM_STRING_MIN_32_CHARS

# BCK Manager integration
BCK_MANAGER_PATH=/opt/bck_manager
BCK_CONFIG_PATH=/opt/bck_manager/config.yaml
BCK_LOG_PATH=/var/log/bck_manager.log

# Database
BCK_WEB_DB_PATH=/opt/bck_manager_web/bck_web.db

# JWT token expiry
BCK_WEB_ACCESS_TOKEN_EXPIRE_HOURS=8
BCK_WEB_REFRESH_TOKEN_EXPIRE_DAYS=30

# Update checker
BCK_WEB_GITHUB_REPO=giuva90/BCK_Manager_Web
BCK_WEB_UPDATE_CHECK_INTERVAL_HOURS=6

# Caddy / TLS
CADDY_HOSTNAME=backup.example.com
CADDY_TLS_MODE=letsencrypt
CADDY_ACME_EMAIL=admin@example.com
